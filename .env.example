# ── Updigitly enrollment/data layer (Phase 2 Chat 2) ─────────────────────────
# Copy to .env.local for local dev; set the same keys in the Vercel dashboard
# for preview/production. Every integration is optional — the app builds and the
# UI runs with these blank; each subsystem degrades safely when unset.

# Public site URL (used for canonical + absolute links)
NEXT_PUBLIC_SITE_URL=https://updigitly.com

# ── Postgres (Supabase) — canonical enrollment/disclosure/audit store ─────────
# Supabase: Settings → Database → Connection string. Use the pooled URI
# (Transaction mode / port 6543) for serverless. Include ?sslmode=require.
DATABASE_URL=

# ── Cloudflare Turnstile — bot protection on public forms ─────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── GoHighLevel (LeadConnector) — CRM/workflow/comms only (never source of truth)
GHL_API_TOKEN=
GHL_LOCATION_ID=
# Defaults are correct for LeadConnector; override only if instructed.
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Optional custom-field IDs (location-specific). Unmapped answers still reach GHL
# inside the qualifier Note, so these can be filled in incrementally.
GHL_FIELD_PLAN=
GHL_FIELD_BILLING=
GHL_FIELD_LOCATIONS=
GHL_FIELD_WEBSITE=
GHL_FIELD_CRM=
GHL_FIELD_NEEDS=
GHL_FIELD_COMPLEXITY=
# Reserved for Chat 3 (opportunity creation)
GHL_PIPELINE_ID=
GHL_STAGE_ID=

# ── Sync worker — bearer token guarding POST /api/sync (cron) ─────────────────
SYNC_SECRET=
